# Copy this file to .env in the repository root before running docker compose.
# Never commit the root .env file. SUPABASE_SERVICE_ROLE_KEY is server-only.

SUPABASE_URL=https://<your-project-ref>.supabase.co
# Use this when a Docker container must call a host-side Supabase CLI stack.
# SUPABASE_DOCKER_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

HOST=0.0.0.0
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_TITLE_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_TRANSCRIPTION_MEDIA_BYTES=25000000
STREAMOS_E2E_MODE=false
TRANSCRIPTION_PROCESSOR_MODE=openai
TRANSCRIPTION_WORKER_CONCURRENCY=1
CLIP_WORKER_CONCURRENCY=1
API_GATEWAY_SECRET=replace-with-at-least-24-character-api-gateway-secret
API_GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_GATEWAY_RATE_LIMIT_ENABLED=true
API_GATEWAY_RATE_LIMIT_MAX=120
API_GATEWAY_RATE_LIMIT_WINDOW_MS=60000
ADMIN_SECRET=replace-with-at-least-24-character-admin-secret
# HMAC secret for signed stream-ended webhooks.
STREAM_EVENT_WEBHOOK_SECRET=replace-with-at-least-24-character-webhook-secret
TWITCH_EVENTSUB_SECRET=replace-with-at-least-24-character-twitch-secret
YOUTUBE_WEBSUB_SECRET=replace-with-at-least-24-character-youtube-secret
YOUTUBE_WEBSUB_VERIFY_TOKEN=replace-with-required-youtube-websub-token
STREAM_JOB_QUEUE_NAME=streamos-stream-jobs
STREAM_JOB_WORKER_CONCURRENCY=5
STREAM_JOB_ALERT_WEBHOOK_URL=

CONTENT_JOB_RETRY_WORKER_BATCH_SIZE=25
CONTENT_JOB_RETRY_WORKER_POLL_INTERVAL_MS=60000
CONTENT_JOB_RETRY_ATTEMPTS=3
CONTENT_JOB_RETRY_BACKOFF_MS=30000
