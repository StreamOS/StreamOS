# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=local
NODE_ENV=development
HOST=0.0.0.0
STREAMOS_DEMO_MODE=false

# Supabase - browser safe
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase - server only
# Use SUPABASE_URL in Railway workers/services. It can match NEXT_PUBLIC_SUPABASE_URL,
# but it must never be sent to the browser with a service-role key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_ENCRYPTION_KEY=base64:replace-with-32-byte-key

# OpenAI / AI providers - server only
# Never define NEXT_PUBLIC_OPENAI_KEY or NEXT_PUBLIC_OPENAI_API_KEY.
# All AI calls must go through services/automation-service.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TITLE_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_TRANSCRIPTION_MEDIA_BYTES=25000000
REPLICATE_API_TOKEN=
STREAMOS_E2E_MODE=false
TRANSCRIPTION_PROCESSOR_MODE=openai

# Twitch OAuth / Webhooks - server only unless explicitly proxied
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_WEBHOOK_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/api/platforms/twitch/callback
TWITCH_SCOPES=user:read:email

# YouTube / Google OAuth - server only unless explicitly proxied
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/platforms/youtube/callback

# TikTok / Kick integrations - server only
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Queue / Jobs
# Upstash/BullMQ needs the Redis protocol URL, not the Upstash REST URL.
# Example: rediss://default:password@host.upstash.io:6379
# Local host services can use redis://localhost:6379/0.
# Docker Compose services use redis://redis:6379/0 internally.
REDIS_URL=
QUEUE_DEFAULT_NAME=streamos-media
CLIP_GENERATION_QUEUE_NAME=streamos-clip-generation
TRANSCRIPTION_QUEUE_NAME=streamos-transcription
TRANSCRIPTION_WORKER_CONCURRENCY=2
CLIP_WORKER_CONCURRENCY=2
STREAM_EVENT_WEBHOOK_SECRET=local-streamos-webhook-secret
CONTENT_JOB_RETRY_WORKER_BATCH_SIZE=25
CONTENT_JOB_RETRY_WORKER_POLL_INTERVAL_MS=60000
CONTENT_JOB_RETRY_ATTEMPTS=3
CONTENT_JOB_RETRY_BACKOFF_MS=30000

# Local service URLs
# Vercel web app calls API_GATEWAY_URL from server actions/route handlers.
API_GATEWAY_URL=http://localhost:4000
# Server-only shared secret for app-facing API gateway routes.
# Required when services/api-gateway runs with NODE_ENV=production.
API_GATEWAY_SECRET=local-api-gateway-secret
API_GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_GATEWAY_RATE_LIMIT_MAX=120
API_GATEWAY_RATE_LIMIT_WINDOW_MS=60000
# Transcription worker calls AUTOMATION_SERVICE_URL. In Railway production, set
# this to the private service URL, for example:
# http://<automation-service>.railway.internal:8000
AUTOMATION_SERVICE_URL=http://localhost:8000
