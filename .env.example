# =============================================================================
# StreamOS - Environment Example
#
# Copy for local web development:
#   cp .env.example apps/web/.env.local
#
# Copy for repository-root services / Docker Compose:
#   cp .env.example .env
#
# Never commit real .env files. Keep service-role keys, provider secrets, OAuth
# tokens, API keys, and webhook secrets server-side only.
#
# Vercel apps/web whitelist:
#   NEXT_PUBLIC_APP_URL, NEXT_PUBLIC_SUPABASE_URL,
#   NEXT_PUBLIC_SUPABASE_ANON_KEY, APP_ENV, STREAMOS_DEMO_MODE,
#   APP_ENCRYPTION_KEY, STREAM_EVENT_WEBHOOK_SECRET, TWITCH_CLIENT_ID,
#   TWITCH_CLIENT_SECRET, TWITCH_REDIRECT_URI, TWITCH_SCOPES,
#   API_GATEWAY_URL, API_GATEWAY_SECRET.
# Supabase service-role, Redis, OpenAI, Replicate, Railway private URLs, and
# non-Twitch provider secrets belong to Railway services/workers or GitHub
# Environments, never Vercel.
# =============================================================================

# -----------------------------------------------------------------------------
# App Runtime
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public HTTPS origin that Twitch can call for EventSub webhooks, without a
# trailing slash. In production this should route to services/api-gateway.
STREAMOS_PUBLIC_URL=https://streamos.example
APP_ENV=local
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
# Optional platform host fallback used by some providers.
HOSTNAME=

# When true, the web app renders demo data and does not require Supabase config.
STREAMOS_DEMO_MODE=false

# -----------------------------------------------------------------------------
# Supabase - Browser Safe
# -----------------------------------------------------------------------------
# These NEXT_PUBLIC_* values are intentionally browser-visible.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Supabase - Server Only
# -----------------------------------------------------------------------------
# Use SUPABASE_URL in Railway services/workers. It can match
# NEXT_PUBLIC_SUPABASE_URL, but it must never be paired with a service-role key
# in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Use this only when Docker containers need to call a host-side Supabase CLI
# stack, for example local E2E runs with `supabase start`.
# SUPABASE_DOCKER_URL=http://host.docker.internal:54321

# 32-byte key for encrypting platform OAuth tokens before persistence.
# Generate:
#   node -e "console.log('base64:' + require('node:crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=base64:replace-with-32-byte-key

# -----------------------------------------------------------------------------
# OpenAI / AI Providers - Server Only
# -----------------------------------------------------------------------------
# Never define any NEXT_PUBLIC_OPENAI* variable.
# All AI calls must go through services/automation-service.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_TITLE_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_TRANSCRIPTION_MEDIA_BYTES=25000000

# Optional future provider integration.
REPLICATE_API_TOKEN=

# E2E-only processor modes: stub or fail. Outside E2E, keep openai.
STREAMOS_E2E_MODE=false
TRANSCRIPTION_PROCESSOR_MODE=openai

# -----------------------------------------------------------------------------
# Twitch OAuth / EventSub - Server Only
# -----------------------------------------------------------------------------
TWITCH_CLIENT_ID=replace-with-twitch-client-id
TWITCH_CLIENT_SECRET=replace-with-twitch-client-secret
TWITCH_REDIRECT_URI=http://localhost:4000/api/auth/twitch/callback
TWITCH_SCOPES=user:read:email moderator:read:followers

# Twitch EventSub callback HMAC secret. Production value must be at least
# 24 characters. Provider webhooks use STREAM_EVENT_WEBHOOK_SECRET; the
# TWITCH_* aliases are kept for older /api/webhooks compatibility paths.
TWITCH_EVENTSUB_SECRET=replace-with-twitch-eventsub-webhook-secret
TWITCH_WEBHOOK_SECRET=replace-with-twitch-eventsub-webhook-secret

# HMAC secret for Twitch EventSub callbacks and internal signed stream-ended
# webhooks. Production value must be at least 24 characters.
STREAM_EVENT_WEBHOOK_SECRET=replace-with-at-least-24-character-webhook-secret

# -----------------------------------------------------------------------------
# YouTube / Google OAuth - Server Only
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_REDIRECT_URI=http://localhost:4000/api/auth/youtube/callback
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.readonly
# Stable HMAC secret for YouTube WebSub POST verification. Do not rotate while
# active YouTube subscriptions exist, or in-flight POST signatures will fail.
YOUTUBE_WEBHOOK_SECRET=replace-with-youtube-webhook-secret
YOUTUBE_WEBSUB_SECRET=replace-with-youtube-websub-secret
YOUTUBE_WEBSUB_VERIFY_TOKEN=replace-with-optional-youtube-websub-token

# Bearer token for Railway/Gateway-owned scheduled renewal tasks.
CRON_SECRET=replace-with-at-least-24-character-cron-secret

# -----------------------------------------------------------------------------
# TikTok / Kick OAuth - Server Only
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/api/auth/tiktok/callback

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=http://localhost:4000/api/auth/kick/callback
KICK_SCOPES=user:read channel:read events:subscribe channel:follow channel:subscription
KICK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Redis / BullMQ Queues
# -----------------------------------------------------------------------------
# Upstash/BullMQ needs the Redis protocol URL, not the Upstash REST URL.
# Production example:
#   rediss://default:password@host.upstash.io:6379
# Local host services:
#   redis://localhost:6379/0
# Docker Compose services use redis://redis:6379/0 internally.
REDIS_URL=redis://localhost:6379/0
QUEUE_DEFAULT_NAME=streamos-media
CLIP_GENERATION_QUEUE_NAME=streamos-clip-generation
TRANSCRIPTION_QUEUE_NAME=streamos-transcription
# Legacy alias; keep aligned with QUEUE_DEFAULT_NAME for webhook media jobs.
STREAM_JOB_QUEUE_NAME=streamos-media

# -----------------------------------------------------------------------------
# API Gateway - services/api-gateway
# -----------------------------------------------------------------------------
API_GATEWAY_URL=http://localhost:4000

# Server-only shared secret for app-facing API gateway routes. Required in
# production and must be at least 24 characters when NODE_ENV=production.
API_GATEWAY_SECRET=replace-with-at-least-24-character-api-gateway-secret
API_GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_GATEWAY_RATE_LIMIT_ENABLED=true
API_GATEWAY_RATE_LIMIT_MAX=120
API_GATEWAY_RATE_LIMIT_WINDOW_MS=60000
ADMIN_SECRET=replace-with-at-least-24-character-admin-secret

# -----------------------------------------------------------------------------
# Automation Service - services/automation-service
# -----------------------------------------------------------------------------
# Transcription and clip workers call this server-side URL. In Railway
# production, prefer the private service URL, for example:
#   http://<automation-service>.railway.internal:8000
AUTOMATION_SERVICE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Workers
# -----------------------------------------------------------------------------
TRANSCRIPTION_WORKER_CONCURRENCY=2
CLIP_WORKER_CONCURRENCY=2
STREAM_JOB_WORKER_CONCURRENCY=5
STREAM_JOB_ALERT_WEBHOOK_URL=

CONTENT_JOB_RETRY_WORKER_BATCH_SIZE=25
CONTENT_JOB_RETRY_WORKER_POLL_INTERVAL_MS=60000
CONTENT_JOB_RETRY_ATTEMPTS=3
CONTENT_JOB_RETRY_BACKOFF_MS=30000

# -----------------------------------------------------------------------------
# Local Tooling / E2E Overrides
# -----------------------------------------------------------------------------
# Optional Python 3.12 executable override for scripts/with-python-312.cjs.
STREAMOS_PYTHON=

# Optional Docker-compatible CLI override for E2E scripts.
DOCKER_BIN=

# Optional Supabase auth user UUID for E2E scripts.
E2E_USER_ID=

# -----------------------------------------------------------------------------
# CI/CD Provider Secrets - GitHub Environments Only
# -----------------------------------------------------------------------------
# These values are consumed by .github/workflows/deploy-*.yml. Keep them in
# GitHub repository or environment secrets, not in committed files. Uncomment
# only for intentional local CLI testing.
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# VERCEL_TOKEN=
# RAILWAY_PROJECT_ID=
# RAILWAY_TOKEN_STAGING=
# RAILWAY_TOKEN_PRODUCTION=
# SUPABASE_DB_URL_STAGING=
# SUPABASE_DB_URL_PRODUCTION=
# DISCORD_WEBHOOK_URL=
