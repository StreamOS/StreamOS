# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=local

# Supabase - browser safe
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase - server only
SUPABASE_SERVICE_ROLE_KEY=
APP_ENCRYPTION_KEY=base64:replace-with-32-byte-key

# OpenAI / AI providers - server only
OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# Twitch OAuth / Webhooks - server only unless explicitly proxied
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_WEBHOOK_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/api/platforms/twitch/callback
TWITCH_SCOPES=user:read:email

# YouTube / Google OAuth - server only unless explicitly proxied
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/platforms/youtube/callback

# TikTok / Kick integrations - server only
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Queue / Jobs
REDIS_URL=
QUEUE_DEFAULT_NAME=streamos-media

# Local service URLs
API_GATEWAY_URL=http://localhost:4000
AUTOMATION_SERVICE_URL=http://localhost:8000
