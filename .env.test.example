# Copy to .env.test for isolated E2E runs against Supabase CLI local stack.
# Run `npx supabase start` and paste the printed local anon/service_role keys.

SUPABASE_URL=http://localhost:54321
SUPABASE_DOCKER_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-start>
SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key-from-supabase-start>

CONTENT_JOB_RETRY_WORKER_BATCH_SIZE=25
CONTENT_JOB_RETRY_WORKER_POLL_INTERVAL_MS=5000
CONTENT_JOB_RETRY_ATTEMPTS=3
CONTENT_JOB_RETRY_BACKOFF_MS=30000

STREAMOS_E2E_MODE=true
TRANSCRIPTION_PROCESSOR_MODE=stub
TRANSCRIPTION_WORKER_CONCURRENCY=1
CLIP_WORKER_CONCURRENCY=1
