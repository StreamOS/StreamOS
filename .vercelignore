# Local dependency and build output directories
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/
out/
**/out/

# Non-web services are deployed outside Vercel and should not be scanned by the
# web deploy upload. This also avoids local Python cache ACL issues on Windows.
services/
workers/

# Python local environments and caches
.venv/
**/.venv/
__pycache__/
**/__pycache__/
.pytest_cache/
**/.pytest_cache/
.ruff_cache/
**/.ruff_cache/
.mypy_cache/
**/.mypy_cache/

# Local tooling caches
.turbo/
**/.turbo/
.cache/
**/.cache/
.tmp/
**/.tmp/

# Test artifacts
playwright-report/
test-results/
**/playwright-report/
**/test-results/

# Local secrets and Vercel state
.env
.env.*
!.env.example
!.env.*.example
.vercel/
