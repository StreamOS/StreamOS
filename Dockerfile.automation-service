FROM python:3.14-slim AS app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app/services/automation-service

COPY services/automation-service/pyproject.toml ./
COPY services/automation-service/src ./src

RUN pip install --no-cache-dir .

WORKDIR /app/services/automation-service/src

EXPOSE 8000

CMD ["sh", "-c", "uvicorn main:app --host ${HOST:-0.0.0.0} --port ${PORT:-8000}"]
