FROM node:22-slim AS app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY scripts/prepare.cjs ./scripts/prepare.cjs
COPY workers/clip-worker ./workers/clip-worker

RUN pnpm install --frozen-lockfile --filter @streamos/clip-worker...
RUN pnpm --filter @streamos/clip-worker... --if-present build

ENV NODE_ENV=production

CMD ["node", "workers/clip-worker/dist/index.js"]
