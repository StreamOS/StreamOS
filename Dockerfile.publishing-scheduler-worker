FROM node:22-slim AS app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY scripts/prepare.cjs ./scripts/prepare.cjs
COPY scripts/lib ./scripts/lib
COPY workers/publishing-scheduler-worker ./workers/publishing-scheduler-worker

RUN pnpm install --frozen-lockfile --filter @streamos/publishing-scheduler-worker...
RUN pnpm --filter @streamos/publishing-scheduler-worker... --if-present build

ENV NODE_ENV=production

CMD ["node", "workers/publishing-scheduler-worker/dist/index.js"]
