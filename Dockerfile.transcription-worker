FROM node:26-slim AS app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY scripts/check-deployment.cjs ./scripts/check-deployment.cjs
COPY workers/transcription-worker ./workers/transcription-worker

RUN pnpm install --frozen-lockfile --filter @streamos/transcription-worker...
RUN pnpm --filter @streamos/transcription-worker... --if-present build

ENV NODE_ENV=production

CMD ["node", "workers/transcription-worker/dist/index.js"]
