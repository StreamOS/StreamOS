# Minimal local environment for apps/web only.
# Copy to apps/web/.env.local and fill placeholders as needed.
#
# Do not add APP_ENCRYPTION_KEY, provider client secrets, webhook secrets,
# Redis credentials, OPENAI_* variables, or SUPABASE_SERVICE_ROLE_KEY here.
# Those belong to Railway services/workers or the repository-root .env.

APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy compatibility alias. Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

STREAMOS_DEMO_MODE=false

API_GATEWAY_URL=http://localhost:4000
API_GATEWAY_SECRET=replace-with-local-api-gateway-secret
