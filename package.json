{
  "name": "streamos-monorepo",
  "version": "0.1.0",
  "description": "StreamOS monorepo for creator discoverability, monetization, automation, branding, multi-platform management, and analytics.",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "e2e:jobs": "node scripts/e2e-content-jobs.cjs",
    "e2e:jobs:local": "node scripts/e2e-content-jobs.cjs --env-file=.env.test",
    "e2e:transcription": "node scripts/e2e-transcription-job.cjs",
    "e2e:transcription:local": "node scripts/e2e-transcription-job.cjs --env-file=.env.test",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f redis api-gateway automation-service clip-worker transcription-worker content-job-retry-worker",
    "infra:ps": "docker compose ps",
    "infra:up": "docker compose up -d redis api-gateway automation-service clip-worker transcription-worker content-job-retry-worker",
    "deployment:check": "node scripts/check-deployment.cjs",
    "lint": "eslint . --max-warnings=0",
    "python:version": "node scripts/with-python-312.cjs python --version",
    "test": "turbo test",
    "test:fastapi": "node scripts/with-python-312.cjs python -m pytest services/automation-service",
    "test:e2e": "playwright test",
    "test:automation": "pnpm test:fastapi",
    "typecheck": "turbo typecheck",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:fastapi && pnpm build",
    "format": "prettier --check \"*.{json,md,yml,yaml}\" \"apps/**/*.{ts,tsx,js,json,md,yml,yaml}\" \"docs/**/*.{ts,tsx,js,json,md,yml,yaml}\" \"e2e/**/*.{ts,tsx,js,json,md,yml,yaml}\" \"packages/**/*.{ts,tsx,js,json,md,yml,yaml}\" \"scripts/**/*.{ts,tsx,js,cjs,json,md,yml,yaml}\" \"services/api-gateway/**/*.{ts,tsx,js,json,md,yml,yaml}\" \"workers/**/*.{ts,tsx,js,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.5.18",
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@types/node": "^22.13.14",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^14.0.0",
    "pnpm": "9.15.4",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
