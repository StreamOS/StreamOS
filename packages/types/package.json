{
  "name": "@streamos/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./jobs": {
      "types": "./src/jobs.ts",
      "import": "./dist/jobs.js",
      "default": "./dist/jobs.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@streamos/config": "workspace:*",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
