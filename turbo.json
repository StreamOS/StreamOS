{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@streamos/web#build": {
      "dependsOn": ["^build", "lint", "typecheck"],
      "env": [
        "APP_ENV",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "STREAMOS_DEMO_MODE"
      ],
      "outputs": [".next/**", "dist/**", "build/**", "!**/.next/cache/**"]
    },
    "build": {
      "dependsOn": ["^build", "lint", "typecheck"],
      "outputs": [".next/**", "dist/**", "build/**", "!**/.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
